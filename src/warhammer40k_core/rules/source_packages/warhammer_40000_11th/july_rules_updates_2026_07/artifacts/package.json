    "rules": [
      {
        "behavior_descriptor": "unnamed_zero_cp_reduces_cost_by_one",
        "rule_id": "modifying-a-stratagem-cp-cost",
        "source_id": "gw-11e-rules-and-event-updates-2026-07-22:universal-rules:modifying-a-stratagem-cp-cost",
        "source_text": "An unnamed rule that would make a friendly unit's Stratagem cost 0CP instead reduces that use's CP cost by 1CP."
      },
      {
        "behavior_descriptor": "repeat_or_limit_exception_requires_named_stratagem",
        "rule_id": "stratagem-repeat-and-limit-exceptions",
        "source_id": "gw-11e-rules-and-event-updates-2026-07-22:universal-rules:stratagem-repeat-and-limit-exceptions",
        "source_text": "A rule can override repeated-use or once-per-turn, round, or battle restrictions only when it names the affected Stratagem."
      },
      {
        "behavior_descriptor": "protective_targeting_range_is_eighteen_inches",
        "rule_id": "stratagems-that-prevent-targeting",
        "source_id": "gw-11e-rules-and-event-updates-2026-07-22:universal-rules:stratagems-that-prevent-targeting",
        "source_text": "A Stratagem effect that prevents ranged targeting beyond 12 inches instead uses an 18-inch threshold."
      },
      {
        "behavior_descriptor": "identical_unit_replacement_once_per_battle",
        "rule_id": "stratagems-that-add-identical-units",
        "source_id": "gw-11e-rules-and-event-updates-2026-07-22:universal-rules:stratagems-that-add-identical-units",
        "source_text": "A Stratagem that adds a new unit identical to a destroyed unit can be used only once per battle."
      }
    ],
