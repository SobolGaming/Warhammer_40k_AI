{
  "$id": "https://warhammer40k-core.local/contracts/v3/annotated-decision-request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actor_id": {"minLength": 1, "type": "string"},
    "decision_type": {"minLength": 1, "type": "string"},
    "interaction": {
      "$ref": "https://warhammer40k-core.local/contracts/v3/interaction-descriptor.schema.json"
    },
    "is_parameterized": {"type": "boolean"},
    "options": {
      "items": {"$ref": "#/$defs/decision_option"},
      "type": "array"
    },
    "payload": {"$ref": "#/$defs/json_value"},
    "request_id": {"minLength": 1, "type": "string"},
    "schema_version": {
      "const": "annotated-decision-request-v1",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "request_id",
    "decision_type",
    "actor_id",
    "payload",
    "options",
    "is_parameterized",
    "interaction"
  ],
  "title": "CORE V2 InteractionAnnotatedDecisionRequestPayload",
  "type": "object",
  "$defs": {
    "decision_option": {
      "additionalProperties": false,
      "properties": {
        "label": {"minLength": 1, "type": "string"},
        "option_id": {"minLength": 1, "type": "string"},
        "payload": {"$ref": "#/$defs/json_value"}
      },
      "required": ["option_id", "label", "payload"],
      "type": "object"
    },
    "json_value": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "number"},
        {"type": "string"},
        {"items": {"$ref": "#/$defs/json_value"}, "type": "array"},
        {
          "additionalProperties": {"$ref": "#/$defs/json_value"},
          "type": "object"
        }
      ]
    }
  }
}
