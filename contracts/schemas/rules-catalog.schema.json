{
  "$id": "https://warhammer40k-core.local/contracts/v1/rules-catalog.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "base_size_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/base_size"
      },
      "type": "object"
    },
    "army_rule_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/army_rule_display"
      },
      "type": "object"
    },
    "catalog_id": {
      "minLength": 1,
      "type": "string"
    },
    "datasheet_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/display_record"
      },
      "type": "object"
    },
    "detachment_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/display_record"
      },
      "type": "object"
    },
    "enhancement_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/display_record"
      },
      "type": "object"
    },
    "faction_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/display_record"
      },
      "type": "object"
    },
    "model_profile_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/display_record"
      },
      "type": "object"
    },
    "projection_schema": {
      "const": "rules-catalog-view-v2",
      "minLength": 1,
      "type": "string"
    },
    "ruleset_id": {
      "$ref": "#/$defs/json_value"
    },
    "source_hash": {
      "minLength": 64,
      "type": "string"
    },
    "source_package_id": {
      "minLength": 1,
      "type": "string"
    },
    "stratagem_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/stratagem_display"
      },
      "type": "object"
    },
    "wargear_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/display_record"
      },
      "type": "object"
    },
    "wargear_option_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/display_record"
      },
      "type": "object"
    },
    "weapon_profile_display_by_id": {
      "additionalProperties": {
        "$ref": "#/$defs/display_record"
      },
      "type": "object"
    }
  },
  "required": [
    "projection_schema",
    "catalog_id",
    "ruleset_id",
    "source_package_id",
    "source_hash",
    "datasheet_display_by_id",
    "model_profile_display_by_id",
    "wargear_display_by_id",
    "weapon_profile_display_by_id",
    "faction_display_by_id",
    "detachment_display_by_id",
    "army_rule_display_by_id",
    "stratagem_display_by_id",
    "enhancement_display_by_id",
    "wargear_option_display_by_id",
    "base_size_display_by_id"
  ],
  "title": "CORE V2 RulesCatalogViewPayload",
  "type": "object",
  "$defs": {
    "base_size": {
      "additionalProperties": false,
      "properties": {
        "base_size_id": {
          "minLength": 1,
          "type": "string"
        },
        "diameter_mm": {
          "type": [
            "number",
            "null"
          ]
        },
        "kind": {
          "minLength": 1,
          "type": "string"
        },
        "length_mm": {
          "type": [
            "number",
            "null"
          ]
        },
        "width_mm": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "required": [
        "base_size_id",
        "kind",
        "diameter_mm",
        "length_mm",
        "width_mm"
      ],
      "type": "object"
    },
    "army_rule_display": {
      "additionalProperties": false,
      "properties": {
        "ability_descriptor_ids": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "army_rule_id": {
          "minLength": 1,
          "type": "string"
        },
        "content_scope": {
          "minLength": 1,
          "type": "string"
        },
        "display_name": {
          "minLength": 1,
          "type": "string"
        },
        "source_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "army_rule_id",
        "display_name",
        "source_id",
        "content_scope",
        "ability_descriptor_ids"
      ],
      "type": "object"
    },
    "display_record": {
      "additionalProperties": {
        "$ref": "#/$defs/json_value"
      },
      "type": "object"
    },
    "json_value": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "items": {
            "$ref": "#/$defs/json_value"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/json_value"
          },
          "type": "object"
        }
      ]
    },
    "stratagem_display": {
      "additionalProperties": false,
      "properties": {
        "ability_descriptor_ids": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "command_point_cost": {
          "minimum": 0,
          "type": "integer"
        },
        "content_scope": {
          "minLength": 1,
          "type": "string"
        },
        "display_name": {
          "minLength": 1,
          "type": "string"
        },
        "source_id": {
          "minLength": 1,
          "type": "string"
        },
        "stratagem_id": {
          "minLength": 1,
          "type": "string"
        },
        "timing_tags": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "stratagem_id",
        "display_name",
        "source_id",
        "content_scope",
        "command_point_cost",
        "timing_tags",
        "ability_descriptor_ids"
      ],
      "type": "object"
    }
  }
}
