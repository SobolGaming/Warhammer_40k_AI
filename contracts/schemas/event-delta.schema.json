{
  "$id": "https://warhammer40k-core.local/contracts/v2/event-delta.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "command_id": {"type": ["string", "null"]},
    "events": {"items": {"$ref": "#/$defs/event_record"}, "type": "array"},
    "from_revision": {"minimum": 0, "type": "integer"},
    "game_id": {"minLength": 1, "type": "string"},
    "has_more": {"type": "boolean"},
    "next_cursor": {"maxLength": 2048, "minLength": 1, "type": "string"},
    "projection_state_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "resync_reason": {
      "enum": [
        null,
        "malformed",
        "expired",
        "ahead",
        "wrong_session",
        "wrong_viewer",
        "revision_mismatch",
        "projection_hash_mismatch"
      ]
    },
    "resync_required": {"type": "boolean"},
    "retention_limit": {"minimum": 1, "type": "integer"},
    "revision_retention_limit": {"minimum": 1, "type": "integer"},
    "schema_version": {"const": "event-delta-v2", "type": "string"},
    "session_id": {"minLength": 1, "type": "string"},
    "supplied_cursor": {"maxLength": 2048, "minLength": 1, "type": "string"},
    "to_revision": {"minimum": 0, "type": "integer"},
    "visibility_role": {
      "enum": ["player", "coach", "delayed_spectator", "administrator"],
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "session_id",
    "game_id",
    "visibility_role",
    "from_revision",
    "to_revision",
    "projection_state_hash",
    "supplied_cursor",
    "next_cursor",
    "has_more",
    "resync_required",
    "resync_reason",
    "command_id",
    "retention_limit",
    "revision_retention_limit",
    "events"
  ],
  "title": "CORE V2 Role-Bound SessionEventDeltaPayload",
  "type": "object",
  "$defs": {
    "event_record": {
      "additionalProperties": false,
      "properties": {
        "event_id": {"minLength": 1, "type": "string"},
        "event_type": {"minLength": 1, "type": "string"},
        "payload": {"$ref": "#/$defs/json_value"},
        "sequence_number": {"minimum": 1, "type": "integer"}
      },
      "required": ["sequence_number", "event_id", "event_type", "payload"],
      "type": "object"
    },
    "json_value": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "number"},
        {"type": "string"},
        {"items": {"$ref": "#/$defs/json_value"}, "type": "array"},
        {"additionalProperties": {"$ref": "#/$defs/json_value"}, "type": "object"}
      ]
    }
  }
}
