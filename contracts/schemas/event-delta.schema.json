{
  "$id": "https://warhammer40k-core.local/contracts/v1/event-delta.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "event-delta-v1",
      "type": "string"
    },
    "cursor": {
      "minimum": 0,
      "type": "integer"
    },
    "events": {
      "items": {
        "$ref": "#/$defs/event_record"
      },
      "type": "array"
    },
    "next_cursor": {
      "minimum": 0,
      "type": "integer"
    },
    "viewer_player_id": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "viewer_player_id",
    "cursor",
    "next_cursor",
    "events"
  ],
  "title": "CORE V2 EventStreamDeltaPayload",
  "type": "object",
  "$defs": {
    "event_record": {
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "minLength": 1,
          "type": "string"
        },
        "event_type": {
          "minLength": 1,
          "type": "string"
        },
        "payload": {
          "$ref": "#/$defs/json_value"
        }
      },
      "required": [
        "event_id",
        "event_type",
        "payload"
      ],
      "type": "object"
    },
    "json_value": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "items": {
            "$ref": "#/$defs/json_value"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/json_value"
          },
          "type": "object"
        }
      ]
    }
  }
}
