{
  "$id": "https://warhammer40k-core.local/contracts/v1/replay-metadata.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {"minLength": 1, "type": "string"},
    "decision_records": {"items": {"type": "object"}, "type": "array"},
    "event_records": {"items": {"type": "object"}, "type": "array"},
    "initial_lifecycle": {"type": "object"},
    "initial_rng_state": {"type": "object"},
    "projection_checkpoints": {
      "items": {"$ref": "#/$defs/projection_checkpoint"},
      "type": "array"
    },
    "schema_version": {"const": "replay-artifact-v1-phase18b", "type": "string"},
    "source_identity": {"$ref": "#/$defs/source_identity"}
  },
  "required": [
    "schema_version",
    "artifact_id",
    "source_identity",
    "initial_rng_state",
    "initial_lifecycle",
    "decision_records",
    "event_records",
    "projection_checkpoints"
  ],
  "title": "CORE V2 ReplayArtifactMetadataPayload",
  "type": "object",
  "$defs": {
    "projection_checkpoint": {
      "additionalProperties": false,
      "properties": {
        "checkpoint_id": {"minLength": 1, "type": "string"},
        "decision_record_index": {"minimum": 0, "type": "integer"},
        "event_count": {"minimum": 0, "type": "integer"},
        "event_log_hash": {"minLength": 64, "type": "string"},
        "projection_schema": {"minLength": 1, "type": "string"},
        "projection_state_hash": {"minLength": 1, "type": "string"},
        "viewer_player_id": {"minLength": 1, "type": "string"}
      },
      "required": [
        "checkpoint_id",
        "decision_record_index",
        "event_count",
        "event_log_hash",
        "viewer_player_id",
        "projection_schema",
        "projection_state_hash"
      ],
      "type": "object"
    },
    "source_identity": {
      "additionalProperties": false,
      "properties": {
        "catalog_hash": {"minLength": 64, "type": "string"},
        "catalog_id": {"minLength": 1, "type": "string"},
        "game_config_hash": {"minLength": 64, "type": "string"},
        "game_id": {"minLength": 1, "type": "string"},
        "ruleset_descriptor_hash": {"minLength": 64, "type": "string"},
        "source_ids": {"items": {"type": "string"}, "type": "array"},
        "source_package_id": {"minLength": 1, "type": "string"}
      },
      "required": [
        "game_id",
        "game_config_hash",
        "ruleset_descriptor_hash",
        "catalog_id",
        "catalog_hash",
        "source_package_id",
        "source_ids"
      ],
      "type": "object"
    }
  }
}
