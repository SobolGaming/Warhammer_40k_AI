{
  "$id": "https://warhammer40k-core.local/contracts/v3/session-command-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "if": {"properties": {"accepted": {"const": true}}},
  "properties": {
    "accepted": {"type": "boolean"},
    "checkpoint": {"$ref": "#/$defs/checkpoint"},
    "committed": {"type": "boolean"},
    "event_range": {"$ref": "#/$defs/event_range"},
    "operation": {
      "enum": [
        "start_session",
        "advance_session",
        "submit_finite_decision",
        "submit_parameterized_decision",
        "close_session"
      ],
      "type": "string"
    },
    "schema_version": {"const": "session-command-result-v3-contract", "type": "string"},
    "session": {"$ref": "https://warhammer40k-core.local/contracts/v3/session-metadata.schema.json"}
  },
  "required": [
    "schema_version",
    "operation",
    "committed",
    "accepted",
    "session",
    "checkpoint",
    "event_range"
  ],
  "then": {"properties": {"committed": {"const": true}}},
  "title": "CORE V2 SessionCommandResultPayload",
  "type": "object",
  "$defs": {
    "checkpoint": {
      "additionalProperties": false,
      "properties": {
        "event_cursor": {"maxLength": 2048, "minLength": 1, "type": "string"},
        "projection_state_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "session_revision": {"minimum": 0, "type": "integer"},
        "viewer_player_id": {"type": ["string", "null"]},
        "visibility_role": {
          "enum": ["player", "coach", "delayed_spectator", "administrator"],
          "type": "string"
        }
      },
      "required": [
        "visibility_role",
        "viewer_player_id",
        "session_revision",
        "projection_state_hash",
        "event_cursor"
      ],
      "type": "object"
    },
    "event_range": {
      "additionalProperties": false,
      "properties": {
        "from_cursor": {"maxLength": 2048, "minLength": 1, "type": "string"},
        "to_cursor": {"maxLength": 2048, "minLength": 1, "type": "string"}
      },
      "required": ["from_cursor", "to_cursor"],
      "type": "object"
    }
  }
}
