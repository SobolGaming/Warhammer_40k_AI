{
  "$id": "https://warhammer40k-core.local/contracts/v3/interaction-conformance.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cases": {
      "items": {"$ref": "#/$defs/case"},
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "schema_version": {
      "const": "interaction-conformance-v1",
      "type": "string"
    }
  },
  "required": ["schema_version", "cases"],
  "title": "CORE V2 Interaction Conformance Cases",
  "type": "object",
  "$defs": {
    "case": {
      "additionalProperties": false,
      "properties": {
        "case_id": {"minLength": 1, "type": "string"},
        "proposal_payload": {
          "oneOf": [
            {"$ref": "https://warhammer40k-core.local/contracts/v1/proposal-payload.schema.json"},
            {"type": "null"}
          ]
        },
        "request": {
          "$ref": "https://warhammer40k-core.local/contracts/v3/annotated-decision-request.schema.json"
        },
        "submission_variant_id": {"minLength": 1, "type": "string"}
      },
      "required": [
        "case_id",
        "request",
        "submission_variant_id",
        "proposal_payload"
      ],
      "type": "object"
    }
  }
}
