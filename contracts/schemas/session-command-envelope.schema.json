{
  "$id": "https://warhammer40k-core.local/contracts/v1/session-command-envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "submission": {
            "properties": {
              "submission_kind": {
                "enum": ["start_session", "advance_session", "close_session"]
              }
            },
            "required": ["submission_kind"]
          }
        }
      },
      "then": {
        "properties": {
          "request_id": {"const": null},
          "result_id": {"const": null}
        }
      },
      "else": {
        "properties": {
          "request_id": {"minLength": 1, "type": "string"},
          "result_id": {"minLength": 1, "type": "string"}
        }
      }
    }
  ],
  "properties": {
    "command_id": {"minLength": 1, "type": "string"},
    "expected_session_revision": {"minimum": 0, "type": "integer"},
    "request_id": {
      "oneOf": [
        {"minLength": 1, "type": "string"},
        {"type": "null"}
      ]
    },
    "result_id": {
      "oneOf": [
        {"minLength": 1, "type": "string"},
        {"type": "null"}
      ]
    },
    "schema_version": {"const": "session-command-envelope-v1", "type": "string"},
    "session_id": {"minLength": 1, "type": "string"},
    "submission": {
      "oneOf": [
        {"$ref": "#/$defs/start_submission"},
        {"$ref": "#/$defs/advance_submission"},
        {"$ref": "#/$defs/close_submission"},
        {"$ref": "#/$defs/finite_submission"},
        {"$ref": "#/$defs/parameterized_submission"}
      ]
    }
  },
  "required": [
    "schema_version",
    "command_id",
    "session_id",
    "expected_session_revision",
    "request_id",
    "result_id",
    "submission"
  ],
  "title": "CORE V2 SessionCommandEnvelopePayload",
  "type": "object",
  "$defs": {
    "advance_submission": {
      "additionalProperties": false,
      "properties": {
        "submission_kind": {"const": "advance_session", "type": "string"}
      },
      "required": ["submission_kind"],
      "type": "object"
    },
    "close_submission": {
      "additionalProperties": false,
      "properties": {
        "submission_kind": {"const": "close_session", "type": "string"}
      },
      "required": ["submission_kind"],
      "type": "object"
    },
    "finite_submission": {
      "additionalProperties": false,
      "properties": {
        "option_id": {"minLength": 1, "type": "string"},
        "submission_kind": {"const": "finite_option", "type": "string"}
      },
      "required": ["submission_kind", "option_id"],
      "type": "object"
    },
    "json_value": {
      "oneOf": [
        {"type": "null"},
        {"type": "boolean"},
        {"type": "number"},
        {"type": "string"},
        {"items": {"$ref": "#/$defs/json_value"}, "type": "array"},
        {
          "additionalProperties": {"$ref": "#/$defs/json_value"},
          "type": "object"
        }
      ]
    },
    "parameterized_submission": {
      "additionalProperties": false,
      "properties": {
        "payload": {"$ref": "#/$defs/json_value"},
        "submission_kind": {"const": "parameterized_payload", "type": "string"}
      },
      "required": ["submission_kind", "payload"],
      "type": "object"
    },
    "start_submission": {
      "additionalProperties": false,
      "properties": {
        "submission_kind": {"const": "start_session", "type": "string"}
      },
      "required": ["submission_kind"],
      "type": "object"
    }
  }
}
