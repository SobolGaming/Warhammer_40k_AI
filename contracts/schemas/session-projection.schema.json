{
  "$id": "https://warhammer40k-core.local/contracts/v3/session-projection.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "event_cursor": {"maxLength": 2048, "minLength": 1, "type": "string"},
    "game_id": {"minLength": 1, "type": "string"},
    "projection": {"$ref": "https://warhammer40k-core.local/contracts/v3/game-view.schema.json"},
    "projection_state_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "retention_limit": {"minimum": 1, "type": "integer"},
    "revision_retention_limit": {"minimum": 1, "type": "integer"},
    "schema_version": {"const": "session-projection-v2-interaction", "type": "string"},
    "session_id": {"minLength": 1, "type": "string"},
    "session_revision": {"minimum": 0, "type": "integer"},
    "visibility_role": {
      "enum": ["player", "coach", "delayed_spectator", "administrator"],
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "session_id",
    "game_id",
    "session_revision",
    "visibility_role",
    "projection_state_hash",
    "event_cursor",
    "retention_limit",
    "revision_retention_limit",
    "projection"
  ],
  "title": "CORE V2 SessionProjectionPayload",
  "type": "object"
}
