{
  "$id": "https://warhammer40k-core.local/contracts/v3/decision-family-coverage.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "families": {
      "items": {"$ref": "#/$defs/family"},
      "type": "array",
      "uniqueItems": true
    },
    "known_external_token_count": {"minimum": 1, "type": "integer"},
    "interaction_kind_count": {"minimum": 1, "type": "integer"},
    "live_scenario_count": {"minimum": 0, "type": "integer"},
    "registered_decision_type_count": {"minimum": 1, "type": "integer"},
    "standard_interaction_kinds": {
      "items": {"$ref": "#/$defs/interaction_kind"},
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "schema_version": {
      "const": "decision-family-coverage-v2-interactions",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "registered_decision_type_count",
    "known_external_token_count",
    "live_scenario_count",
    "interaction_kind_count",
    "standard_interaction_kinds",
    "families"
  ],
  "title": "CORE V2 DecisionFamilyCoveragePayload",
  "type": "object",
  "$defs": {
    "family": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {"coverage_status": {"const": "live_scenario"}},
            "required": ["coverage_status"]
          },
          "then": {"properties": {"example_path": {"minLength": 1, "type": "string"}}},
          "else": {"properties": {"example_path": {"type": "null"}}}
        },
        {
          "if": {
            "properties": {"registry_scope": {"const": "redaction"}},
            "required": ["registry_scope"]
          },
          "then": {
            "properties": {
              "coverage_status": {"const": "redaction_only"},
              "submission_kind": {"const": "not_submittable"}
            }
          }
        }
      ],
      "properties": {
        "coverage_status": {
          "enum": ["live_scenario", "envelope_only", "redaction_only"],
          "type": "string"
        },
        "decision_type": {"minLength": 1, "type": "string"},
        "example_path": {"type": ["string", "null"]},
        "interaction_kinds": {
          "items": {"$ref": "#/$defs/interaction_kind"},
          "type": "array",
          "uniqueItems": true
        },
        "registry_scope": {
          "enum": ["registered", "nested", "redaction"],
          "type": "string"
        },
        "submission_kind": {
          "enum": ["finite", "parameterized", "not_submittable"],
          "type": "string"
        }
      },
      "required": [
        "decision_type",
        "registry_scope",
        "submission_kind",
        "coverage_status",
        "example_path",
        "interaction_kinds"
      ],
      "type": "object"
    },
    "interaction_kind": {
      "enum": [
        "battlefield_point_placement",
        "confirmation",
        "dice_selection",
        "entity_selection",
        "finite_option_list",
        "model_pose_placement",
        "multi_model_placement",
        "opportunity_window",
        "ordered_sequencing",
        "path_editor",
        "quantity_selection",
        "roster_construction",
        "weapon_allocation_matrix"
      ],
      "type": "string"
    }
  }
}
